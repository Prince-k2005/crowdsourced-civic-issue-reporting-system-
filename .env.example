# ========================================
# CivicFlow — Environment Variables
# ========================================

# ── Supabase (get from supabase.com → Project Settings → API) ──
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ── Database (Supabase → Settings → Database → Connection string URI) ──
# Use the "Connection Pooling" URI with port 6543
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── App ──
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
UPLOAD_DIR=./uploads

# ── AI (optional — leave empty for now) ──
GOOGLE_AI_API_KEY=

# ── Frontend (Next.js public vars — must start with NEXT_PUBLIC_) ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_DEMO_EMAIL=demo@civicflow.local
NEXT_PUBLIC_DEMO_PASSWORD=demo123456
